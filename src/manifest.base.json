{
  "manifest_version": 3,
  "name": "Gallery Mode",
  "version": "0.1.0",
  "description": "Replace ads with masterpieces from museums around the world.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gallery Mode"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.artic.edu/*",
    "https://collectionapi.metmuseum.org/*",
    "https://openaccess-api.clevelandart.org/*",
    "https://www.artic.edu/*",
    "https://images.metmuseum.org/*",
    "https://openaccess-cdn.clevelandart.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["styles/replacement.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/replacement.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
